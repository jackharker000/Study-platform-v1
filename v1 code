if (!quiz) return;
if (quiz.currentIndex + 1 >= quiz.questions.length) {
navigate(‘home’);
return;
}
quiz.currentIndex++;
quiz.flashcardFlipped = false;
saveState();
render();
}

function prevFlashcard() {
const quiz = state.quiz;
if (!quiz || quiz.currentIndex <= 0) return;
quiz.currentIndex–;
quiz.flashcardFlipped = false;
saveState();
render();
}

/* ═══════════════════════════════════════════════════════════════════
SECTION 8: EVENT BINDING & KEYBOARD
═══════════════════════════════════════════════════════════════════ */

function bindEvents() {
// Text input live save
const ta = document.getElementById(‘textAnswer’);
if (ta) {
ta.addEventListener(‘input’, () => {
if (state.quiz) state.quiz.pendingText = ta.value;
});
}
}

document.addEventListener(‘keydown’, (e) => {
if (state.currentScreen !== ‘quiz’ || !state.quiz) return;
const quiz = state.quiz;
const idx = quiz.currentIndex;
const q = quiz.questions[idx];
const answered = quiz.answers[idx] !== undefined;

// Flashcard keys
if (state.mode === ‘flashcard’) {
if (e.key === ’ ’ || e.key === ‘Enter’) { e.preventDefault(); flipFlashcard(); }
if (e.key === ‘ArrowRight’) nextFlashcard();
if (e.key === ‘ArrowLeft’) prevFlashcard();
return;
}

// MCQ number keys
if (q.questionType === ‘mcq’ && !answered && [‘1’,‘2’,‘3’,‘4’].includes(e.key)) {
selectMcqOption(parseInt(e.key) - 1);
}

// Submit
if (e.key === ‘Enter’ && !answered && canSubmit(q, idx)) {
if (document.activeElement?.tagName === ‘TEXTAREA’) return; // Don’t submit while typing
e.preventDefault();
submitAnswer();
}

// Next
if ((e.key === ‘ArrowRight’ || e.key === ‘Enter’) && answered) {
if (document.activeElement?.tagName === ‘TEXTAREA’) return;
e.preventDefault();
nextQuestion();
}
});

