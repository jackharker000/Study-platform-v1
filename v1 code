/* ═══════════════════════════════════════════════════════════════════
   SECTION 2: STATE MANAGEMENT
   ═══════════════════════════════════════════════════════════════════ */

const STATE_KEY = 'rev_platform_v2';

function loadState() {
  try {
    const saved = localStorage.getItem(STATE_KEY);
    if (saved) return JSON.parse(saved);
  } catch(e) {}
  return defaultState();
}

function defaultState() {
  return {
    currentScreen: 'home',
    selectedSubject: null,
    filters: { paper: 'all', topic: 'all', difficulty: 'all', questionType: 'all' },
    mode: 'practice',
    quizConfig: { count: 10 },
    quiz: null,
    history: [],
    mistakes: [],
    stats: {},
    topicStats: {},
    confidenceLog: [],
  };
}

let state = loadState();

function saveState() {
  try { localStorage.setItem(STATE_KEY, JSON.stringify(state)); } catch(e) {}
}

/* ═══════════════════════════════════════════════════════════════════
   SECTION 3: FILTERING & SELECTION
   ═══════════════════════════════════════════════════════════════════ */

function filterQuestions(subject, filters) {
  return QUESTIONS.filter(q => {
    if (subject && q.subject !== subject) return false;
    if (filters.paper !== 'all' && q.paper !== filters.paper) return false;
    if (filters.topic !== 'all' && q.topic !== filters.topic) return false;
    if (filters.difficulty !== 'all' && q.difficulty !== filters.difficulty) return false;
    if (filters.questionType !== 'all' && q.questionType !== filters.questionType) return false;
    return true;
  });
}

function getTopicsForSubject(subjectId) {
  const topics = new Set();
  QUESTIONS.filter(q => q.subject === subjectId).forEach(q => topics.add(q.topic));
  return [...topics];
}

function getPapersForSubject(subjectId) {
  const papers = new Set();
  QUESTIONS.filter(q => q.subject === subjectId).forEach(q => papers.add(q.paper));
  return [...papers];
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function selectQuestions(pool, count, mode) {
  if (mode === 'weakness') {
    pool.sort((a, b) => {
      const aWrong = (state.topicStats[a.topic]?.wrong || 0);
      const bWrong = (state.topicStats[b.topic]?.wrong || 0);
      return bWrong - aWrong;
    });
    return pool.slice(0, count);
  }
  if (mode === 'mistakes') {
    const mistakeIds = new Set(state.mistakes.map(m => m.id));
    pool = pool.filter(q => mistakeIds.has(q.id));
  }
  return shuffle(pool).slice(0, count);
}

/* ═══════════════════════════════════════════════════════════════════
   SECTION 4: PERSISTENCE & ANALYTICS
   ═══════════════════════════════════════════════════════════════════ */

function recordAnswer(question, userAnswer, correct, timeMs, confidence) {
  const entry = {
    id: question.id,
    subject: question.subject,
    topic: question.topic,
    difficulty: question.difficulty,
    correct,
    confidence,
    timeMs,
    timestamp: Date.now(),
  };
  state.history.push(entry);

  // Update stats
  if (!state.stats[question.subject]) state.stats[question.subject] = { correct: 0, total: 0 };
  state.stats[question.subject].total++;
  if (correct) state.stats[question.subject].correct++;

  // Update topic stats
  if (!state.topicStats[question.topic]) state.topicStats[question.topic] = { correct: 0, wrong: 0 };
  if (correct) state.topicStats[question.topic].correct++;
  else {
    state.topicStats[question.topic].wrong++;
    if (!state.mistakes.find(m => m.id === question.id)) {
      state.mistakes.push({ id: question.id, count: 1, lastWrong: Date.now() });
    } else {
      const m = state.mistakes.find(m => m.id === question.id);
      m.count++;
      m.lastWrong = Date.now();
    }
  }

  // Remove from mistakes if answered correctly
  if (correct) {
    state.mistakes = state.mistakes.filter(m => m.id !== question.id);
  }

  saveState();
}

function getOverallAccuracy() {
  const total = state.history.length;
  if (!total) return 0;
  const correct = state.history.filter(h => h.correct).length;
  return Math.round((correct / total) * 100);
}

function getSubjectAccuracy(subjectId) {
  const s = state.stats[subjectId];
  if (!s || !s.total) return 0;
  return Math.round((s.correct / s.total) * 100);
}

function getWeakTopics(limit = 5) {
  return Object.entries(state.topicStats)
    .filter(([, v]) => (v.correct + v.wrong) >= 2)
    .map(([topic, v]) => ({ topic, pct: Math.round(v.correct / (v.correct + v.wrong) * 100), total: v.correct + v.wrong }))
    .sort((a, b) => a.pct - b.pct)
    .slice(0, limit);
}

/* ═══════════════════════════════════════════════════════════════════
   SECTION 5: TUTOR / AI-STYLE FEEDBACK
   ═══════════════════════════════════════════════════════════════════ */

function generateFeedback(question, userAnswer, correct) {
  const fb = { correct };

  if (question.questionType === 'mcq') {
    fb.correctText = question.options[question.correctAnswer];
    if (!correct && typeof userAnswer === 'number') {
      fb.userText = question.options[userAnswer];
    }
  }

  fb.explanation = question.explanation;
  fb.steps = question.teachingSteps || [];
  fb.mistakes = question.commonMistakes || [];
  fb.examTip = generateExamTip(question);
  fb.nextAdvice = correct
    ? "Great work! Try a harder question on this topic next."
    : `Review ${question.subtopic} before attempting similar questions.`;

  return fb;
}

function generateExamTip(q) {
  const tips = {
    'mcq': "In MCQ papers, eliminate obviously wrong answers first. If two options look similar, one is likely the answer.",
    'calculation': "Always show your working — partial marks are awarded even if the final answer is wrong.",
    'short-answer': "Use the mark allocation as a guide: if it's worth 3 marks, make 3 distinct points.",
    'essay': "Plan before writing. Use PEE paragraphs (Point, Evidence, Explanation) and link back to the question.",
  };
  return tips[q.questionType] || "Read the question carefully and check your answer before moving on.";
}

function generateEssayFeedback(question, userText) {
  const wordCount = userText.trim().split(/\s+/).length;
  const hasQuotes = /["'"].+?["']/.test(userText) || /['"].+?['"]/.test(userText);
  const hasBecause = /because|therefore|this shows|this suggests|this implies/i.test(userText);
  const hasHowever = /however|although|on the other hand|conversely/i.test(userText);

  const strengths = [];
  const improvements = [];

  if (wordCount > 50) strengths.push("Good length and development of ideas.");
  else improvements.push("Try to develop your points more fully. Aim for at least 80-100 words.");

  if (hasBecause) strengths.push("Good use of explanatory connectives.");
  else improvements.push("Use words like 'because', 'this shows', 'this suggests' to explain your points.");

  if (hasQuotes) strengths.push("Evidence/quotations included.");
  else improvements.push("Include quotations or specific evidence to support your points.");

  if (hasHowever) strengths.push("Shows ability to consider different perspectives.");
  else improvements.push("Try to include counterarguments using 'however' or 'on the other hand'.");

  let score = 0;
  const maxMarks = question.marks;
  if (wordCount > 30) score++;
  if (wordCount > 80) score++;
  if (hasBecause) score++;
  if (hasQuotes) score++;
  if (hasHowever) score++;
  if (wordCount > 120) score++;
  score = Math.min(score, maxMarks);

  return {
    strengths,
    improvements,
    estimatedScore: score,
    maxMarks,
    nextTarget: score < maxMarks ? `Target: ${score + 1}/${maxMarks}. ${improvements[0] || ''}` : "Excellent! Try a harder question.",
  };
}

