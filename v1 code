<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Revision Platform</title>
<style>
/* ═══════════════════════════════════════════
   CSS VARIABLES & RESET
   ═══════════════════════════════════════════ */
:root {
  --bg: #0b0e14;
  --bg-card: #111620;
  --bg-card-hover: #161d2a;
  --bg-input: #0d1018;
  --border: #1c2333;
  --border-focus: #3b82f6;
  --text: #c8cdd5;
  --text-dim: #6b7280;
  --text-bright: #e8ecf1;
  --accent: #3b82f6;
  --accent-glow: #3b82f620;
  --green: #22c55e;
  --green-bg: #22c55e15;
  --red: #ef4444;
  --red-bg: #ef444415;
  --amber: #f59e0b;
  --amber-bg: #f59e0b15;
  --purple: #a855f7;
  --purple-bg: #a855f715;
  --cyan: #06b6d4;
  --radius: 10px;
  --radius-sm: 6px;
  --radius-lg: 14px;
  --shadow: 0 2px 12px #0003;
  --font-display: 'Palatino Linotype', 'Book Antiqua', Palatino, Georgia, serif;
  --font-body: 'Segoe UI', 'SF Pro Text', system-ui, sans-serif;
  --font-mono: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  --transition: 0.2s ease;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 15px; scroll-behavior: smooth; }

body {
font-family: var(–font-body);
background: var(–bg);
color: var(–text);
min-height: 100vh;
line-height: 1.6;
-webkit-font-smoothing: antialiased;
}

/* Subtle noise texture */
body::before {
content: ‘’;
position: fixed; inset: 0;
background: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘0.03’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 0;
}

/* ═══════════ SCROLLBAR ═══════════ */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #2a3040; border-radius: 3px; }

/* ═══════════ LAYOUT ═══════════ */
#app {
position: relative;
z-index: 1;
max-width: 860px;
margin: 0 auto;
padding: 20px 16px 100px;
}

/* ═══════════ ANIMATIONS ═══════════ */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(12px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
from { opacity: 0; }
to { opacity: 1; }
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
@keyframes slideRight {
from { opacity: 0; transform: translateX(-16px); }
to { opacity: 1; transform: translateX(0); }
}

.fade-up { animation: fadeUp .4s ease both; }
.fade-in { animation: fadeIn .3s ease both; }
.stagger-1 { animation-delay: .05s; }
.stagger-2 { animation-delay: .1s; }
.stagger-3 { animation-delay: .15s; }
.stagger-4 { animation-delay: .2s; }
.stagger-5 { animation-delay: .25s; }

/* ═══════════ TYPOGRAPHY ═══════════ */
h1 {
font-family: var(–font-display);
font-size: 1.85rem;
color: var(–text-bright);
font-weight: 600;
letter-spacing: -.01em;
}
h2 {
font-size: .78rem;
font-weight: 600;
color: var(–text-dim);
text-transform: uppercase;
letter-spacing: 1.2px;
margin-bottom: 10px;
}
h3 {
font-family: var(–font-display);
font-size: 1.15rem;
color: var(–text-bright);
font-weight: 600;
}

/* ═══════════ HEADER ═══════════ */
.header {
text-align: center;
padding: 28px 0 18px;
}
.header-brand {
display: inline-flex;
align-items: center;
gap: 10px;
margin-bottom: 6px;
}
.header-logo {
width: 32px; height: 32px;
background: linear-gradient(135deg, var(–accent), var(–purple));
border-radius: 8px;
display: flex; align-items: center; justify-content: center;
font-weight: 800; font-size: 14px; color: #fff;
}
.header-sub {
font-size: .82rem;
color: var(–text-dim);
margin-top: 2px;
}

/* ═══════════ NAV TABS ═══════════ */
.nav-tabs {
display: flex;
gap: 4px;
padding: 4px;
background: var(–bg-card);
border: 1px solid var(–border);
border-radius: var(–radius);
margin-bottom: 24px;
overflow-x: auto;
}
.nav-tab {
flex: 1;
padding: 9px 12px;
border: none;
background: transparent;
color: var(–text-dim);
font-size: .8rem;
font-weight: 500;
border-radius: var(–radius-sm);
cursor: pointer;
transition: var(–transition);
white-space: nowrap;
font-family: var(–font-body);
}
.nav-tab:hover { color: var(–text); background: var(–bg-card-hover); }
.nav-tab.active {
background: var(–accent);
color: #fff;
font-weight: 600;
}

/* ═══════════ CARDS ═══════════ */
.card {
background: var(–bg-card);
border: 1px solid var(–border);
border-radius: var(–radius-lg);
padding: 24px;
margin-bottom: 16px;
}
.card-flush { padding: 0; overflow: hidden; }

/* ═══════════ SUBJECT GRID ═══════════ */
.subject-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
gap: 10px;
margin-bottom: 24px;
}
.subject-card {
padding: 18px 16px;
background: var(–bg-card);
border: 1px solid var(–border);
border-radius: var(–radius);
cursor: pointer;
transition: var(–transition);
position: relative;
overflow: hidden;
}
.subject-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 3px;
background: var(–subject-color, var(–accent));
opacity: 0;
transition: var(–transition);
}
.subject-card:hover {
border-color: var(–subject-color, var(–accent));
background: var(–bg-card-hover);
transform: translateY(-1px);
}
.subject-card:hover::before { opacity: 1; }
.subject-card.selected {
border-color: var(–subject-color, var(–accent));
box-shadow: 0 0 0 1px var(–subject-color, var(–accent));
}
.subject-card.selected::before { opacity: 1; }
.subject-name {
font-family: var(–font-display);
font-size: 1rem;
font-weight: 600;
color: var(–text-bright);
margin-bottom: 2px;
}
.subject-meta {
font-size: .75rem;
color: var(–text-dim);
}
.subject-stat {
display: inline-flex;
align-items: center;
gap: 4px;
margin-top: 8px;
font-size: .72rem;
color: var(–text-dim);
background: var(–bg);
padding: 3px 8px;
border-radius: 20px;
}

/* ═══════════ FILTER ROW ═══════════ */
.filter-row {
display: flex;
flex-wrap: wrap;
gap: 8px;
margin-bottom: 16px;
}
.filter-select {
padding: 7px 12px;
background: var(–bg-input);
border: 1px solid var(–border);
border-radius: var(–radius-sm);
color: var(–text);
font-size: .78rem;
font-family: var(–font-body);
cursor: pointer;
transition: var(–transition);
min-width: 120px;
}
.filter-select:focus {
outline: none;
border-color: var(–accent);
box-shadow: 0 0 0 2px var(–accent-glow);
}

/* ═══════════ CHIPS ═══════════ */
.chip-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
.chip {
padding: 5px 12px;
border-radius: 20px;
border: 1px solid var(–border);
background: var(–bg-card);
color: var(–text-dim);
font-size: .72rem;
font-weight: 500;
cursor: pointer;
transition: var(–transition);
}
.chip:hover { border-color: var(–text-dim); color: var(–text); }
.chip.active {
background: var(–accent);
border-color: var(–accent);
color: #fff;
}

/* ═══════════ BADGE ═══════════ */
.badge {
display: inline-block;
padding: 2px 9px;
border-radius: 20px;
font-size: .68rem;
font-weight: 600;
text-transform: capitalize;
}
.badge-easy { background: var(–green-bg); color: var(–green); }
.badge-medium { background: var(–amber-bg); color: var(–amber); }
.badge-hard { background: var(–red-bg); color: var(–red); }
.badge-vhard { background: var(–purple-bg); color: var(–purple); }
.badge-topic { background: #3b82f612; color: var(–accent); }
.badge-type { background: #06b6d412; color: var(–cyan); }

/* ═══════════ BUTTONS ═══════════ */
.btn {
display: inline-flex;
align-items: center;
justify-content: center;
gap: 6px;
padding: 11px 24px;
border: none;
border-radius: var(–radius);
font-size: .85rem;
font-weight: 600;
font-family: var(–font-body);
cursor: pointer;
transition: var(–transition);
}
.btn-primary {
background: var(–accent);
color: #fff;
}
.btn-primary:hover { background: #2563eb; transform: translateY(-1px); }
.btn-primary:disabled { opacity: .35; cursor: not-allowed; transform: none; }
.btn-ghost {
background: transparent;
border: 1px solid var(–border);
color: var(–text-dim);
}
.btn-ghost:hover { border-color: var(–text-dim); color: var(–text); }
.btn-danger {
background: transparent;
border: 1px solid var(–red)30;
color: var(–red);
}
.btn-danger:hover { background: var(–red-bg); }
.btn-sm { padding: 7px 14px; font-size: .78rem; }
.btn-block { width: 100%; }

/* ═══════════ PROGRESS BAR ═══════════ */
.progress-wrap {
margin-bottom: 18px;
}
.progress-meta {
display: flex;
justify-content: space-between;
margin-bottom: 5px;
font-size: .75rem;
}
.progress-track {
height: 5px;
background: var(–border);
border-radius: 3px;
overflow: hidden;
}
.progress-fill {
height: 100%;
background: var(–accent);
border-radius: 3px;
transition: width .5s ease;
}

/* ═══════════ QUESTION CARD ═══════════ */
.q-card {
background: var(–bg-card);
border: 1px solid var(–border);
border-radius: var(–radius-lg);
padding: 28px;
animation: fadeUp .35s ease both;
}
.q-meta {
display: flex;
flex-wrap: wrap;
gap: 6px;
margin-bottom: 10px;
}
.q-source {
font-size: .72rem;
color: var(–text-dim);
margin-bottom: 4px;
}
.q-prompt {
font-family: var(–font-display);
font-size: 1.12rem;
color: var(–text-bright);
line-height: 1.65;
margin-bottom: 22px;
font-weight: 500;
}

/* MCQ Options */
.q-options { display: flex; flex-direction: column; gap: 8px; }
.q-option {
display: flex;
align-items: center;
gap: 14px;
padding: 14px 16px;
background: var(–bg);
border: 1px solid var(–border);
border-radius: var(–radius);
cursor: pointer;
transition: var(–transition);
font-size: .92rem;
color: var(–text);
width: 100%;
text-align: left;
font-family: var(–font-body);
}
.q-option:hover:not(.locked) {
border-color: var(–accent);
background: #3b82f608;
}
.q-option.selected:not(.locked) {
border-color: var(–accent);
background: var(–accent-glow);
}
.q-option.correct {
border-color: var(–green);
background: var(–green-bg);
color: var(–green);
}
.q-option.incorrect {
border-color: var(–red);
background: var(–red-bg);
color: var(–red);
opacity: .7;
}
.q-option.locked { cursor: default; }
.q-option-letter {
display: flex;
align-items: center;
justify-content: center;
width: 30px; height: 30px;
border-radius: 50%;
background: var(–border);
font-size: .78rem;
font-weight: 700;
flex-shrink: 0;
color: var(–text-dim);
}
.q-option.correct .q-option-letter { background: var(–green); color: #fff; }
.q-option.incorrect .q-option-letter { background: var(–red); color: #fff; }

/* Short answer / essay input */
.q-input {
width: 100%;
padding: 14px 16px;
background: var(–bg);
border: 1px solid var(–border);
border-radius: var(–radius);
color: var(–text);
font-size: .92rem;
font-family: var(–font-body);
resize: vertical;
transition: var(–transition);
line-height: 1.6;
}
.q-input:focus {
outline: none;
border-color: var(–accent);
box-shadow: 0 0 0 2px var(–accent-glow);
}
.q-input-label {
font-size: .75rem;
color: var(–text-dim);
margin-bottom: 6px;
}

/* Confidence selector */
.confidence-row {
display: flex;
gap: 8px;
margin-top: 16px;
padding-top: 16px;
border-top: 1px solid var(–border);
}
.confidence-btn {
flex: 1;
padding: 8px;
border: 1px solid var(–border);
background: var(–bg);
border-radius: var(–radius-sm);
color: var(–text-dim);
font-size: .73rem;
font-weight: 500;
cursor: pointer;
transition: var(–transition);
font-family: var(–font-body);
text-align: center;
}
.confidence-btn:hover { border-color: var(–text-dim); color: var(–text); }
.confidence-btn.active-confident { border-color: var(–green); color: var(–green); background: var(–green-bg); }
.confidence-btn.active-unsure { border-color: var(–amber); color: var(–amber); background: var(–amber-bg); }
.confidence-btn.active-guessed { border-color: var(–red); color: var(–red); background: var(–red-bg); }

/* ═══════════ FEEDBACK PANEL ═══════════ */
.feedback {
margin-top: 20px;
animation: fadeUp .3s ease both;
}
.feedback-header {
padding: 14px 18px;
border-radius: var(–radius) var(–radius) 0 0;
font-weight: 700;
font-size: .92rem;
}
.feedback-correct {
background: var(–green-bg);
border: 1px solid #22c55e30;
color: var(–green);
}
.feedback-incorrect {
background: var(–red-bg);
border: 1px solid #ef444430;
color: var(–red);
}
.feedback-body {
padding: 18px;
background: var(–bg);
border: 1px solid var(–border);
border-top: none;
border-radius: 0 0 var(–radius) var(–radius);
}
.feedback-section {
margin-bottom: 14px;
}
.feedback-section:last-child { margin-bottom: 0; }
.feedback-section-title {
font-size: .72rem;
font-weight: 600;
color: var(–accent);
text-transform: uppercase;
letter-spacing: .5px;
margin-bottom: 5px;
}
.feedback-text {
font-size: .85rem;
line-height: 1.65;
color: var(–text);
}
.feedback-step {
font-size: .82rem;
color: var(–text);
padding: 6px 0 6px 16px;
border-left: 2px solid var(–border);
margin-bottom: 4px;
}
.feedback-mistake {
font-size: .8rem;
color: var(–text-dim);
padding: 4px 0;
}
.feedback-mistake::before {
content: ’⚠ ’;
color: var(–amber);
}

/* ═══════════ FLASHCARD ═══════════ */
.flashcard-container {
perspective: 1000px;
margin-bottom: 20px;
}
.flashcard {
position: relative;
min-height: 280px;
cursor: pointer;
transform-style: preserve-3d;
transition: transform .6s ease;
}
.flashcard.flipped { transform: rotateY(180deg); }
.flashcard-face {
position: absolute;
inset: 0;
backface-visibility: hidden;
background: var(–bg-card);
border: 1px solid var(–border);
border-radius: var(–radius-lg);
padding: 32px;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
text-align: center;
}
.flashcard-back {
transform: rotateY(180deg);
background: var(–bg-card-hover);
}
.flashcard-label {
font-size: .7rem;
color: var(–text-dim);
text-transform: uppercase;
letter-spacing: 1px;
margin-bottom: 14px;
}
.flashcard-content {
font-family: var(–font-display);
font-size: 1.1rem;
color: var(–text-bright);
line-height: 1.7;
}

/* ═══════════ DASHBOARD STATS ═══════════ */
.stat-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
gap: 10px;
margin-bottom: 20px;
}
.stat-card {
background: var(–bg-card);
border: 1px solid var(–border);
border-radius: var(–radius);
padding: 16px;
text-align: center;
}
.stat-value {
font-family: var(–font-display);
font-size: 1.6rem;
font-weight: 700;
color: var(–text-bright);
}
.stat-label {
font-size: .72rem;
color: var(–text-dim);
margin-top: 2px;
}
.bar-chart { margin-bottom: 14px; }
.bar-row {
display: flex;
align-items: center;
gap: 10px;
margin-bottom: 8px;
}
.bar-label {
width: 120px;
font-size: .78rem;
color: var(–text);
flex-shrink: 0;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}
.bar-track {
flex: 1;
height: 8px;
background: var(–border);
border-radius: 4px;
overflow: hidden;
}
.bar-fill {
height: 100%;
border-radius: 4px;
transition: width .5s ease;
}
.bar-pct {
width: 44px;
text-align: right;
font-size: .75rem;
font-weight: 600;
color: var(–text-dim);
}

/* ═══════════ TIMER ═══════════ */
.timer {
font-family: var(–font-mono);
font-size: .78rem;
color: var(–text-dim);
display: flex;
align-items: center;
gap: 4px;
}
.timer-dot {
width: 6px; height: 6px;
border-radius: 50%;
background: var(–green);
animation: pulse 1.5s ease infinite;
}

/* ═══════════ ACTIONS ROW ═══════════ */
.actions {
display: flex;
gap: 8px;
margin-top: 16px;
}
.actions-spread {
justify-content: space-between;
}

/* ═══════════ MARK SCHEME ═══════════ */
.mark-scheme {
background: var(–bg);
border: 1px solid var(–border);
border-radius: var(–radius);
padding: 16px;
margin-top: 12px;
}
.ms-point {
font-size: .82rem;
color: var(–text);
padding: 4px 0 4px 18px;
position: relative;
}
.ms-point::before {
content: ‘✓’;
position: absolute;
left: 0;
color: var(–green);
font-weight: 700;
}

/* ═══════════ ESSAY FEEDBACK ═══════════ */
.essay-feedback {
border: 1px solid var(–border);
border-radius: var(–radius);
overflow: hidden;
margin-top: 14px;
}
.ef-section {
padding: 14px 16px;
border-bottom: 1px solid var(–border);
}
.ef-section:last-child { border-bottom: none; }
.ef-title {
font-size: .72rem;
font-weight: 600;
text-transform: uppercase;
letter-spacing: .5px;
margin-bottom: 4px;
}
.ef-strengths .ef-title { color: var(–green); }
.ef-improvements .ef-title { color: var(–amber); }
.ef-score .ef-title { color: var(–accent); }
.ef-text {
font-size: .84rem;
color: var(–text);
line-height: 1.6;
}

/* ═══════════ EMPTY STATE ═══════════ */
.empty-state {
text-align: center;
padding: 48px 20px;
color: var(–text-dim);
}
.empty-icon {
font-size: 2.5rem;
margin-bottom: 12px;
opacity: .4;
}
.empty-text {
font-size: .9rem;
}

/* ═══════════ SCREEN VISIBILITY ═══════════ */
.screen { display: none; }
.screen.active { display: block; }

/* ═══════════ RESPONSIVE ═══════════ */
@media (max-width: 600px) {
#app { padding: 12px 10px 80px; }
h1 { font-size: 1.4rem; }
.q-card { padding: 18px; }
.subject-grid { grid-template-columns: 1fr; }
.stat-grid { grid-template-columns: repeat(2, 1fr); }
.filter-row { gap: 6px; }
.filter-select { min-width: 100px; font-size: .73rem; }
.nav-tab { padding: 7px 8px; font-size: .7rem; }
}

/* ═══════════ HINT ═══════════ */
.hint-box {
background: var(–amber-bg);
border: 1px solid #f59e0b30;
border-radius: var(–radius);
padding: 14px 16px;
margin-top: 12px;
animation: fadeUp .3s ease both;
}
.hint-label {
font-size: .7rem;
font-weight: 600;
color: var(–amber);
text-transform: uppercase;
letter-spacing: .5px;
margin-bottom: 4px;
}
.hint-text {
font-size: .84rem;
color: var(–text);
line-height: 1.6;
}

/* ═══════════ EXAM TIP ═══════════ */
.exam-tip {
background: var(–purple-bg);
border: 1px solid #a855f730;
border-radius: var(–radius);
padding: 12px 14px;
margin-top: 10px;
}
.exam-tip-label {
font-size: .68rem;
font-weight: 600;
color: var(–purple);
text-transform: uppercase;
letter-spacing: .5px;
margin-bottom: 3px;
}
.exam-tip-text {
font-size: .82rem;
color: var(–text);
line-height: 1.55;
}

/* Keyboard hint */
.kbd-hint {
font-size: .68rem;
color: var(–text-dim);
text-align: center;
margin-top: 10px;
}
kbd {
display: inline-block;
padding: 1px 6px;
background: var(–border);
border-radius: 3px;
font-family: var(–font-mono);
font-size: .65rem;
}
</style>

</head>
<body>
<div id="app"></div>

<script>
/* ═══════════════════════════════════════════════════════════════════
   SECTION 1: QUESTION BANK (Unified Schema)
