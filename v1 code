}

function startQuiz() {
const pool = filterQuestions(state.selectedSubject, state.filters);
const questions = selectQuestions(pool, state.mode === ‘flashcard’ ? pool.length : state.quizConfig.count, state.mode);
if (!questions.length) return;

state.quiz = {
questions,
currentIndex: 0,
answers: {},
pendingAnswer: null,
pendingText: ‘’,
pendingConfidence: null,
hintShown: false,
flashcardFlipped: false,
startTime: Date.now(),
questionStartTime: Date.now(),
};
state.currentScreen = ‘quiz’;
saveState();
render();
}

function startMistakeReplay() {
state.mode = ‘mistakes’;
state.selectedSubject = null;
const mistakeIds = new Set(state.mistakes.map(m => m.id));
const questions = shuffle(QUESTIONS.filter(q => mistakeIds.has(q.id)));
if (!questions.length) return;
state.quiz = {
questions,
currentIndex: 0,
answers: {},
pendingAnswer: null,
pendingText: ‘’,
pendingConfidence: null,
hintShown: false,
startTime: Date.now(),
questionStartTime: Date.now(),
};
state.currentScreen = ‘quiz’;
saveState();
render();
}

function startWeaknessMode() {
state.mode = ‘weakness’;
state.selectedSubject = null;
const questions = selectQuestions([…QUESTIONS], 10, ‘weakness’);
if (!questions.length) return;
state.quiz = {
questions,
currentIndex: 0,
answers: {},
pendingAnswer: null,
pendingText: ‘’,
pendingConfidence: null,
hintShown: false,
startTime: Date.now(),
questionStartTime: Date.now(),
};
state.currentScreen = ‘quiz’;
saveState();
render();
}

function selectMcqOption(idx) {
if (!state.quiz || state.quiz.answers[state.quiz.currentIndex] !== undefined) return;
state.quiz.pendingAnswer = idx;
render();
}

function setConfidence(level) {
if (!state.quiz) return;
state.quiz.pendingConfidence = level;
render();
}

function canSubmit(q, idx) {
if (state.quiz.answers[idx] !== undefined) return false;
if (q.questionType === ‘mcq’) return state.quiz.pendingAnswer !== null;
return true;
}

function submitAnswer() {
const quiz = state.quiz;
if (!quiz) return;
const idx = quiz.currentIndex;
const q = quiz.questions[idx];
if (quiz.answers[idx] !== undefined) return;

const timeMs = Date.now() - quiz.questionStartTime;
let userAnswer, correct;

if (q.questionType === ‘mcq’) {
userAnswer = quiz.pendingAnswer;
correct = userAnswer === q.correctAnswer;
} else {
const textEl = document.getElementById(‘textAnswer’);
userAnswer = textEl ? textEl.value.trim() : ‘’;
quiz.pendingText = userAnswer;

```
if (q.questionType === 'calculation' && q.correctAnswer) {
  const cleaned = userAnswer.replace(/[^0-9.\-\/]/g, '').trim();
  correct = cleaned === String(q.correctAnswer) || userAnswer.toLowerCase().includes(String(q.correctAnswer).toLowerCase());
} else if (q.questionType === 'short-answer' && q.correctAnswer) {
  correct = userAnswer.toLowerCase().includes(String(q.correctAnswer).toLowerCase());
} else {
  correct = null; // Essay or non-markable
}
```

}

quiz.answers[idx] = {
userAnswer,
correct,
confidence: quiz.pendingConfidence,
timeMs,
};

recordAnswer(q, userAnswer, correct === true, timeMs, quiz.pendingConfidence);
quiz.pendingAnswer = null;
quiz.pendingConfidence = null;
quiz.hintShown = false;

saveState();
render();
}

function nextQuestion() {
const quiz = state.quiz;
if (!quiz) return;
if (quiz.currentIndex + 1 >= quiz.questions.length) {
state.currentScreen = ‘results’;
} else {
quiz.currentIndex++;
quiz.pendingAnswer = null;
quiz.pendingText = ‘’;
quiz.pendingConfidence = null;
quiz.hintShown = false;
quiz.questionStartTime = Date.now();
}
saveState();
render();
}

function skipQuestion() {
nextQuestion();
}

function endQuiz() {
state.currentScreen = ‘results’;
saveState();
render();
}

function showHint() {
if (state.quiz) {
state.quiz.hintShown = true;
render();
}
}

function flipFlashcard() {
if (state.quiz) {
state.quiz.flashcardFlipped = !state.quiz.flashcardFlipped;
render();
}
}

function nextFlashcard() {
