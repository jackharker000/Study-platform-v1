# ── Turso (cloud database for question metadata) ───────────────────────────────
# Get these from: https://app.turso.tech → your database → Connect
TURSO_URL=libsql://study-questions-jackharker000.aws-ap-northeast-1.turso.io
TURSO_TOKEN=your-write-token-here   # paste your read/write token (for migration only)

# ── Cloudflare R2 (object storage for question images) ─────────────────────────
# R2_ACCOUNT_ID: Cloudflare dashboard → right sidebar → Account ID
# R2_ACCESS_KEY + R2_SECRET: R2 → Manage R2 API Tokens → Create Token (Object Write)
# R2_BUCKET: name of the bucket you created (e.g. study-questions-pdfs)
# R2_PUBLIC_URL: R2 → bucket → Settings → Public Access URL (e.g. https://pub-abc123.r2.dev)
R2_ACCOUNT_ID=abc123def456
R2_ACCESS_KEY=your_access_key_id
R2_SECRET=your_secret_access_key
R2_BUCKET=study-questions-pdfs
R2_PUBLIC_URL=https://pub-abc123def456.r2.dev

# ── Local database paths ───────────────────────────────────────────────────────
# DB_PATH: full path to master.db on your Windows machine
# PDF_ROOT: folder that contains the IGCSE/ subfolder with question PDFs
DB_PATH=C:\Users\OEM\Downloads\scraper-claude-scrape-organize-past-papers-w635I\database\master.db
PDF_ROOT=C:\Users\OEM\Downloads\scraper-claude-scrape-organize-past-papers-w635I\database
